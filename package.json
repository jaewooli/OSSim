{
  "name": "os-simulator",
  "private": true,
  "version": "0.1.0",
  "description": "Interactive operating-system simulator built with React, TypeScript, and Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts",
    "preview": "vite preview",
    "start": "vite preview --host 127.0.0.1 --port 8082"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.12",
    "typescript": "~6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.2"
  }
}
